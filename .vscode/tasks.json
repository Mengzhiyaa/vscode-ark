{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch ark extension",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".+",
          "endsPattern": "\\[esbuild\\] watching for changes\\.\\.\\."
        }
      }
    },
    {
      "label": "watch supervisor extension",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}/../vscode-supervisor"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".+",
          "endsPattern": "\\[esbuild\\] watching for changes\\.\\.\\."
        }
      }
    },
    {
      "label": "watch split extensions",
      "dependsOn": [
        "watch ark extension",
        "watch supervisor extension"
      ],
      "dependsOrder": "parallel"
    }
  ]
}
